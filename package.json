{
  "name": "devicebase",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@11.1.2",
  "description": "DeviceBase JavaScript SDK for remote device automation",
  "author": "Devicebase (https://devicebase.cn)",
  "license": "MIT",
  "homepage": "https://github.com/devicebase/js-devicebase#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devicebase/js-devicebase.git"
  },
  "bugs": {
    "url": "https://github.com/devicebase/js-devicebase/issues"
  },
  "keywords": [
    "devicebase",
    "device-automation",
    "android",
    "ios",
    "remote-control",
    "testing"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/devicebase.es.js",
      "require": "./dist/devicebase.umd.js",
      "default": "./dist/devicebase.es.js"
    }
  },
  "main": "./dist/devicebase.umd.js",
  "module": "./dist/devicebase.es.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.lib.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "version": "auto-changelog-plus -p && git add CHANGELOG.md",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^22.19.19",
    "auto-changelog-plus": "^1.2.4",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^3.2.4"
  }
}
